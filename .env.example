# -------- Active Directory --------
# Your AD DNS domain (e.g. contoso.local, company.org)
AD_DOMAIN=example.local

# NetBIOS name of your domain (usually the first part in UPPERCASE)
AD_NETBIOS=EXAMPLE

# Optional: specific Domain Controller hostname. Leave empty for DNS autodiscovery.
AD_DC=

# AD group whose members are authorized to use Galinette
AD_ADMIN_GROUP=Galinette-Admins

# -------- Deployment --------
# Port exposed on the Docker host (change if 8082 is taken)
FRONTEND_PORT=8082

# Set to "false" if you access Galinette in HTTP (dev/testing only).
# Keep "true" in production behind HTTPS.
COOKIE_SECURE=true

# Allowed origins for CORS (must match your public URL)
CORS_ORIGINS=["https://galinette.example.local"]
